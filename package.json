    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "lucide-svelte": "^0.475.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.0.6",
